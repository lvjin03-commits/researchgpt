{
  "manifest_version": 3,
  "name": "ResearchGPT Scholar Saver",
  "description": "Download Google Scholar PDFs in Chrome and save them to selected ResearchGPT folders.",
  "version": "0.2.8",
  "permissions": ["storage", "tabs"],
  "host_permissions": [
    "https://scholar.google.com/*",
    "https://*/*"
  ],
  "externally_connectable": {
    "matches": [
      "https://*/*"
    ]
  },
  "action": {
    "default_title": "ResearchGPT Scholar Saver",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://scholar.google.com/*"],
      "css": ["content.css"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://researchgpt-ivory.vercel.app/extension/connect*"
      ],
      "js": ["connect-bridge.js"],
      "run_at": "document_idle"
    }
  ]
}
