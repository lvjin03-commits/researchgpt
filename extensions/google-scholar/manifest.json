{
  "manifest_version": 3,
  "name": "ResearchAI Scholar Saver",
  "description": "Save Google Scholar results to your ResearchAI literature library.",
  "version": "0.2.0",
  "permissions": ["storage"],
  "host_permissions": [
    "https://scholar.google.com/*",
    "https://*/*",
    "http://localhost/*"
  ],
  "action": {
    "default_title": "ResearchAI Scholar Saver",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://scholar.google.com/*"],
      "css": ["content.css"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
