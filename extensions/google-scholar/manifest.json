{
  "manifest_version": 3,
  "name": "ResearchAI Scholar Saver",
  "description": "Save Google Scholar PDFs to selected ResearchGPT folders.",
  "version": "0.2.1",
  "permissions": ["storage"],
  "host_permissions": [
    "https://scholar.google.com/*",
    "https://*/*",
    "http://localhost/*"
  ],
  "externally_connectable": {
    "matches": [
      "http://localhost:3000/*",
      "https://*/*"
    ]
  },
  "action": {
    "default_title": "ResearchAI Scholar Saver",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://scholar.google.com/*"],
      "css": ["content.css"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "http://localhost:3000/extension/connect*",
        "http://127.0.0.1:3000/extension/connect*"
      ],
      "js": ["connect-bridge.js"],
      "run_at": "document_idle"
    }
  ]
}
