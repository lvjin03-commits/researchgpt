# Copy this file to .env.local and fill in your values.

# AI provider: openai | openrouter (openrouter not yet implemented)
AI_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
OPENAI_VISION_MODEL=gpt-4.1-mini

# Google Scholar search results via SerpApi
SERPAPI_API_KEY=your_serpapi_api_key_here

# OpenRouter (future)
# OPENROUTER_API_KEY=your_openrouter_api_key_here
# OPENROUTER_MODEL=openai/gpt-4o-mini

# Supabase Auth
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Run supabase/migrations/001_chat_history.sql in the Supabase SQL Editor
# before using cloud chat history sync.
# Run supabase/migrations/002_chat_attachments_storage.sql before uploading
# chat attachments to Supabase Storage.
# Run supabase/migrations/003_literature_tracker.sql before using Literature Tracker.
# Run supabase/migrations/004_literature_source_taxonomy.sql for discipline-based sources.
# Run supabase/migrations/005_literature_folders.sql for literature library folders.
# Run supabase/migrations/006_literature_paper_workspace.sql for paper notes and workspace analysis.
